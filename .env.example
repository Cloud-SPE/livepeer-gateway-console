# livepeer-gateway-console — local dev env example.
# Copy to .env and fill in. Never commit .env.

# Bearer token for /api/* (>= 32 chars). /healthz is the only unauth route.
ADMIN_TOKEN=replace-me-with-a-random-32+-char-string-here

# Chain RPC (Arbitrum One mainnet by default).
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4

# Daemon socket paths inside the container. These default values match the
# upstream livepeer-modules-project gateway-archetype's named-volume mount
# points (deploy/gateway/compose.yaml). Override only if you know why.
RESOLVER_SOCKET_PATH=/var/run/livepeer/resolver/service-registry.sock
SENDER_SOCKET_PATH=/var/run/livepeer/sender/payment.sock

LOG_LEVEL=info
LOG_FORMAT=json

# Public hostname (only used by compose.prod.yaml's Traefik labels).
GATEWAY_CONSOLE_PUBLIC_HOST=
