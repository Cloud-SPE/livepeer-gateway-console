# livepeer-gateway-console — local dev env example.
# Copy to .env and fill in. Never commit .env.

# Bearer token for /api/* (>= 32 chars). /healthz is the only unauth route.
ADMIN_TOKEN=replace-me-with-a-random-32+-char-string-here

# Chain RPC (Arbitrum One mainnet by default).
CHAIN_RPC=https://arb1.arbitrum.io/rpc
CHAIN_ID=42161
CONTROLLER_ADDRESS=0xD8E8328501E9645d16Cf49539efC04f734606ee4

# Optional explicit registry contract to match the gateway archetype's
# selected registry surface (standard ServiceRegistry vs AIServiceRegistry).
# When unset, the console resolves ServiceRegistry via Controller.
SERVICE_REGISTRY_ADDRESS=

# Daemon socket paths inside the container. These default values match the
# upstream livepeer-modules-project gateway-archetype's named-volume mount
# points (deploy/gateway/compose.yaml). Override only if you know why.
RESOLVER_SOCKET_PATH=/var/run/livepeer/resolver/service-registry.sock
SENDER_SOCKET_PATH=/var/run/livepeer/sender/payment.sock

# Routing-dashboard chain-enrichment cache TTL (seconds). The
# BondingManager pool walk + per-orch ServiceRegistry serviceURI reads
# are memoized for this window. Bump up if your RPC is slow.
CHAIN_READ_TTL_SEC=30

# routing_observations hydration cadence (seconds). The background
# worker polls Resolver.GetAuditLog at this interval and bulk-inserts
# new rows. Set 0 to disable the worker entirely.
RESOLVER_AUDIT_POLL_INTERVAL_SEC=30

# Hot-wallet identity for the sender view. The PayerDaemon owns the
# keystore via its own bind-mount but does NOT expose the address /
# balance via proto, so configure it here. Optional: when unset,
# /api/sender/wallet returns 503 wallet_not_configured.
SENDER_ADDRESS=

# Optional informational floor (wei, decimal string). The dashboard
# surfaces a "below floor" pill when the wallet balance dips under
# this. The daemon-side ticket-rejection floor is configured separately
# on the daemon itself.
MIN_BALANCE_WEI=

LOG_LEVEL=info
LOG_FORMAT=json

# Public hostname (only used by compose.prod.yaml's Traefik labels).
GATEWAY_CONSOLE_PUBLIC_HOST=
