{
  "name": "livepeer-gateway-console",
  "version": "0.0.1",
  "private": true,
  "description": "Public-facing operator console for Livepeer gateway/bridge entities — routing dashboard + capability search + sender wallet view + audit log + Refresh actions.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/main.js",
  "workspaces": [
    "bridge-ui/shared",
    "bridge-ui/admin"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "npm run build -w admin",
    "dev": "node --import tsx --watch src/main.ts",
    "dev:ui": "npm run dev -w admin",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "proto:gen:payments": "rm -rf src/providers/payerDaemon/gen && mkdir -p src/providers/payerDaemon/gen && buf generate --template buf.gen.payments.yaml",
    "proto:gen:registry": "rm -rf src/providers/resolver/gen && mkdir -p src/providers/resolver/gen && buf generate --template buf.gen.registry.yaml",
    "proto:gen": "npm run proto:gen:payments && npm run proto:gen:registry",
    "docker:build": "docker build -t livepeer-gateway-console:local .",
    "docker:tag": "scripts/docker-tag.sh",
    "docker:push": "scripts/docker-push.sh"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@grpc/grpc-js": "^1.14.3",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.29.1",
    "pino": "^9.5.0",
    "viem": "^2.21.42",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.68.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^1.6.1",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.39.4",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "ts-proto": "^2.11.6",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.6.1"
  }
}
